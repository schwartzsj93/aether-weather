# --------------------------------------------------------------------------
# AI Weatherman (Claude)
# --------------------------------------------------------------------------
# When unset, the app falls back to its built-in rule-based summarizer.
# When set, the AI Forecast Briefing card streams in a Claude-generated
# narrative tailored to the selected tone.
#
# ⚠️  SECURITY NOTE
# Vite exposes any VITE_-prefixed env var to the client bundle. That's fine
# for local development, but DO NOT ship a production build with your
# personal Anthropic API key baked in. For production, proxy through a
# tiny serverless function (Cloudflare Worker, Vercel Edge, etc.) that
# adds the Authorization header server-side and forwards the request.

VITE_LLM_PROVIDER=local              # local | anthropic
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-opus-4-6 # claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5

# --------------------------------------------------------------------------
# Optional premium upgrades — the app works without these.
# --------------------------------------------------------------------------

# MapTiler — higher-quality dark vector basemap
VITE_MAPTILER_KEY=

# Tomorrow.io — minute-by-minute precipitation nowcasts
VITE_TOMORROW_API_KEY=

# Visual Crossing — deep historical archive
VITE_VISUAL_CROSSING_API_KEY=
